# Copy this to .env and fill in values
# Never commit .env to git!

# Database (matches docker-compose.yml)
DATABASE_URL="postgresql://taskflow:taskflow_dev@localhost:5432/taskflow"

# Redis (matches docker-compose.yml)
REDIS_URL="redis://localhost:6379"

# JWT — change these to random strings in production!
JWT_ACCESS_SECRET="super-secret-access-key-change-me"
JWT_REFRESH_SECRET="super-secret-refresh-key-change-me"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Server
PORT=4000
NODE_ENV=development

# Client URL for CORS
CLIENT_URL="http://localhost:3000"
